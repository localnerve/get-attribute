{
  "name": "@localnerve/get-attribute",
  "version": "4.30.0",
  "description": "Get an attribute from a webpage, echo to stdout",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint .",
    "test": "node -e \"require('fs').mkdirSync('coverage',{recursive:true})\" && node --import ./__tests__/globals/index.js --test --experimental-test-coverage --test-coverage-exclude=\"**/__tests__/**\" --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=./coverage/lcov.info --experimental-test-isolation=none \"./__tests__/**/*.spec.js\"",
    "test:cli": "bin/get-attribute --url=https://m.twitch.tv/gigaohmbiological/home --selector='a[href^=\"/videos\"]' --attribute=href --useprop=true --timeout=5000 --launchargs='{\"headless\":true}'"
  },
  "bin": {
    "get-attribute": "./bin/get-attribute"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localnerve/get-attribute.git"
  },
  "keywords": [
    "puppeteer",
    "web",
    "attribute"
  ],
  "author": "Alex Grant <alex@localnerve.com> (https://www.localnerve.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/localnerve/get-attribute/issues"
  },
  "homepage": "https://github.com/localnerve/get-attribute#readme",
  "dependencies": {
    "@localnerve/debug": "^1.0.13",
    "puppeteer": "^24.42.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^17.24.0",
    "express": "^5.2.1",
    "globals": "^17.5.0",
    "server-destroy": "^1.0.1"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=23"
  }
}
